INIT_BLOCK:
    MOV %1, 0
    MOV %2, 0
    JMP OUTER_BLOCK

OUTER_BLOCK:
    BEQ %1, 10, INNER_BLOCK, OUTER_BODY

OUTER_BODY:
    ADD %1, %1, 1
    JMP OUTER_BLOCK

INNER_BLOCK:
    BEQ %2, 5, RET_BLOCK, INNER_BODY

INNER_BODY:
    ADD %2, %2, 1
    JMP INNER_BLOCK

RET_BLOCK:
    ADD %3, %1, %2
    RET